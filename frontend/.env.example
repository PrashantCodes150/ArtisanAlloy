# Frontend Environment Variables

# API URL - Backend server URL (Render deployment)
# Update this to your Render backend URL after deployment
VITE_API_URL=https://your-backend-name.onrender.com/api/v1
VITE_BACKEND_URL=https://your-backend-name.onrender.com

VITE_APP_NAME=F Jewelry
VITE_USE_MOCK_AUTH=false

# Razorpay Key ID (Public key - safe to expose)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
