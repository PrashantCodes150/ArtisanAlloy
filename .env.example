# Frontend Environment Variables

# API URL - Backend server URL
# OPTION 1: SEPARATE DEPLOYMENT (Vercel Frontend + Render Backend)
#   VITE_API_URL=https://your-backend.onrender.com/api/v1
#   VITE_BACKEND_URL=https://your-backend.onrender.com
# OPTION 2: MONOLITH DEPLOYMENT (Everything on Vercel)
#   VITE_API_URL=/api/v1
#   VITE_BACKEND_URL= (leave empty or omit)
# OPTION 3: LOCAL DEVELOPMENT
#   VITE_API_URL=http://localhost:5000/api/v1
VITE_API_URL=/api/v1
VITE_BACKEND_URL=
VITE_APP_NAME=F Jewelry
VITE_USE_MOCK_AUTH=false

# Full-Stack Configuration (Add backend variables here for Vercel dashboard)
# MONGODB_URI=
# JWT_SECRET=
# CLOUDINARY_CLOUD_NAME=
# RAZORPAY_KEY_ID=

# For Production (update with your domain)
# VITE_API_URL=https://api.yourdomain.com/api/v1

# Razorpay Key ID (Public key - safe to expose)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
