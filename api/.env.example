# Server Configuration
NODE_ENV=production
PORT=10000

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/Artisan-Alloy
# For MongoDB Atlas, use:
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster.xxxxx.mongodb.net/Artisan-Alloy?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_IN=7

# Refresh Token
REFRESH_TOKEN_SECRET=your-refresh-token-secret-change-in-production-min-32-chars
REFRESH_TOKEN_EXPIRES_IN=30d

# Frontend URL (for CORS and email links)
# Update this to your Vercel frontend URL after deployment
FRONTEND_URL=https://your-frontend.vercel.app

# Additional allowed origins (comma-separated for multiple domains)
# Example: https://Artisan-Alloy.vercel.app,https://Artisan-Alloy-git-feature.vercel.app
ALLOWED_ORIGINS=

# Email Configuration (for password reset, order confirmations)
# For Gmail, enable 2FA and create App Password: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password
EMAIL_FROM=ArtisanAlloy <noreply@Artisan-Alloy.com>

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Google OAuth Configuration
# Get credentials from: https://console.developers.google.com/
# Update callback URL to: https://your-backend-name.onrender.com/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# Razorpay (Payment Gateway)
# Get keys from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
# Webhook secret from: Dashboard > Webhooks > Create webhook
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# RENDER DEPLOYMENT SETTINGS
# ============================================
# Build Command: npm install && npm run build
# Start Command: npm run start
# Environment: Node
# Node Version: 18
# Port: 10000 (Render assigns this dynamically)
# Health Check: GET /api/v1/health
