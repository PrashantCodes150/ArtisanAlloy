import { Request, Response, NextFunction } from 'express';
import Cart, { ICart, ICartItem } from '../models/Cart.model';
import { IProduct } from '../models/Product.model';
import { AppError } from '../utils/AppError';
import { asyncHandler } from '../middleware/errorHandler';
import { logger } from '../utils/logger';
import nodemailer from 'nodemailer';

// Define interfaces for populated documents to ensure type safety
interface PopulatedCartItem extends ICartItem {
  product: IProduct;
}

interface PopulatedCart extends ICart {
  items: PopulatedCartItem[];
  userEmail: string; // Assuming these are populated or added dynamically
  userName: string;
  totalAmount: number;
}


/**
 * Schedule abandoned cart recovery email
 * POST /api/v1/marketing/abandoned-cart/recover
 */
export const scheduleRecoveryEmail = asyncHandler(async (req: Request, res: Response, next: NextFunction) => {
  const { cartId, delayMinutes = 60 } = req.body;

  if (!cartId) {
    return next(new AppError('Cart ID is required', 400));
  }

  try {
    const cart = await Cart.findById(cartId).populate<{ items: PopulatedCartItem[] }>('items.product');
    
    if (!cart) {
      return next(new AppError('Cart not found', 404));
    }

    // Check if cart is abandoned (older than specified delay)
    const lastActivity = new Date(cart.updatedAt);
    const timeSinceLastActivity = Date.now() - lastActivity.getTime();
    const thresholdTime = delayMinutes * 60 * 1000; // Convert to milliseconds

    if (timeSinceLastActivity < thresholdTime) {
      return next(new AppError('Cart is not yet considered abandoned', 400));
    }

    // This assumes user details are on the cart, which might require populating the user
    const populatedCart = cart as unknown as PopulatedCart;

    // Schedule recovery email
    const emailData = {
      cartId,
      userEmail: populatedCart.userEmail,
      userName: populatedCart.userName,
      cartItems: populatedCart.items,
      cartValue: populatedCart.total,
      lastActivity: populatedCart.updatedAt,
      recoveryEmailSent: false
    };

    // This would normally be handled by a job queue
    // For demo, we'll send it immediately
    await sendAbandonedCartEmail(populatedCart);

    logger.info(`Abandoned cart recovery email scheduled for cart: ${cartId}`);

    res.status(200).json({
      status: 'success',
      message: 'Abandoned cart recovery email scheduled',
      data: emailData
    });

  } catch (error: unknown) {
    logger.error('Error scheduling recovery email:', error);
    next(new AppError('Failed to schedule recovery email', 500));
  }
});

/**
 * Get abandoned cart analytics
 * GET /api/v1/marketing/abandoned-cart/analytics
 */
export const getAbandonedCartAnalytics = asyncHandler(async (req: Request, res: Response, next: NextFunction) => {
  const { period = '30' } = req.query;
  const days = parseInt(period as string);

  try {
    // Mock analytics data
    const startDate = new Date();
    startDate.setDate(startDate.getDate() - days);

    const mockAnalytics = {
      totalAbandonedCarts: 145,
      recoveryRate: 18.5, // percentage
      recoveredRevenue: 125000,
      recoveryEmailsSent: 120,
      emailsOpened: 78,
      emailsClicked: 22,
      averageTimeToRecovery: '4.5 hours',
      topAbandonmentReasons: [
        { reason: 'High shipping costs', percentage: 35 },
        { reason: 'Complex checkout', percentage: 28 },
        { reason: 'Payment issues', percentage: 22 },
        { reason: 'Comparison shopping', percentage: 15 }
      ],
      dailyStats: [
        { date: '2024-01-10', abandonedCarts: 12, recovered: 2 },
        { date: '2024-01-11', abandonedCarts: 15, recovered: 3 },
        { date: '2024-01-12', abandonedCarts: 18, recovered: 2 }
      ]
    };

    res.status(200).json({
      status: 'success',
      message: 'Abandoned cart analytics retrieved successfully',
      data: {
        ...mockAnalytics,
        period: `${days} days`
      }
    });

  } catch (error: unknown) {
    logger.error('Error fetching abandoned cart analytics:', error);
    next(new AppError('Failed to fetch analytics', 500));
  }
});

/**
 * Process email tracking events (webhooks)
 * POST /api/v1/marketing/abandoned-cart/track
 */
export const trackEmailEvent = asyncHandler(async (req: Request, res: Response, next: NextFunction) => {
  const { event, emailId, cartId } = req.body;

  if (!event || !emailId) {
    return next(new AppError('Event and email ID are required', 400));
  }

  try {
    switch (event) {
      case 'opened':
        await updateEmailTracking(emailId, { emailOpened: true });
        break;
      case 'clicked':
        await updateEmailTracking(emailId, { emailClicked: true });
        break;
      case 'recovered':
        await updateCartRecovery(cartId, true);
        break;
      default:
        logger.warn(`Unknown tracking event: ${event}`);
    }

    res.status(200).json({
      status: 'success',
      message: 'Tracking event recorded'
    });

  } catch (error: unknown) {
    logger.error('Error tracking email event:', error);
    next(new AppError('Failed to track event', 500));
  }
});

/**
 * Send abandoned cart recovery email
 */
const sendAbandonedCartEmail = async (cart: PopulatedCart) => {
  try {
    const transporter = nodemailer.createTransport({
      service: 'gmail', // In production, use real SMTP
      auth: {
        user: process.env.EMAIL_USER || 'your-email@gmail.com',
        pass: process.env.EMAIL_PASS || 'your-app-password'
      }
    });

    const emailContent = generateAbandonedCartEmail(cart);
    
    await transporter.sendMail({
      from: process.env.EMAIL_FROM || '"ArtisanAlloy" <noreply@ArtisanAlloy.com>',
      to: cart.userEmail,
      subject: emailContent.subject,
      html: emailContent.html,
      text: emailContent.text
    });

    logger.info(`Abandoned cart recovery email sent to: ${cart.userEmail}`);

  } catch (error: unknown) {
    logger.error('Error sending abandoned cart email:', error);
    throw error;
  }
};

