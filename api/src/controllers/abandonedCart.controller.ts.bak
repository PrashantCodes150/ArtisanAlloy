          background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
          color: white;
          text-decoration: none;
          padding: 15px 30px;
          border-radius: 6px;
          font-weight: bold;
          font-size: 16px;
          margin: 20px 0;
          text-align: center;
        }
        .features {
          display: grid;
          grid-template-columns: 1fr 1fr;
          gap: 15px;
          margin: 30px 0;
        }
        .feature {
          text-align: center;
          padding: 15px;
          background: #f8f9fa;
          border-radius: 8px;
        }
        .feature-icon {
          font-size: 24px;
          color: #667eea;
          margin-bottom: 10px;
        }
        .feature-title {
          font-weight: bold;
          margin-bottom: 5px;
          color: #333;
        }
        .feature-description {
          font-size: 14px;
          color: #666;
        }
        .footer {
          text-align: center;
          margin-top: 30px;
          padding-top: 20px;
          border-top: 1px solid #e9ecef;
          color: #999;
          font-size: 12px;
        }
        .coupon-code {
          background: #fff3cd;
          color: #333;
