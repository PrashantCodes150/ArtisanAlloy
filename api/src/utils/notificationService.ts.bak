import { Server as SocketIOServer, Socket } from 'socket.io';
import http from 'http';

// Define notification types
export interface NotificationPayload {
  type: 'ORDER_STATUS' | 'NEW_MESSAGE' | 'PROMOTION' | 'STOCK_UPDATE' | 'CUSTOMER_SUPPORT';
  title: string;
  message: string;
  userId?: string;
  orderId?: string;
  productId?: string;
  timestamp: Date;
}

class NotificationService {
  private io: SocketIOServer | null = null;
  private connectedSockets: Map<string, Socket> = new Map();

  initialize(server: http.Server) {
    this.io = new SocketIOServer(server, {
      cors: {
        origin: process.env.FRONTEND_URL || "http://localhost:5173",
        methods: ["GET", "POST"]
      }
    });

    this.io.on('connection', (socket: Socket) => {
      console.log('User connected:', socket.id);

      // Handle user authentication
      socket.on('authenticate', (userId: string) => {
        this.connectedSockets.set(userId, socket);
        socket.join(userId);
        console.log(`User ${userId} authenticated and joined room`);
      });

      socket.on('disconnect', () => {
        console.log('User disconnected:', socket.id);
        // Remove socket from connected sockets
        for (let [userId, sock] of this.connectedSockets) {
          if (sock.id === socket.id) {
            this.connectedSockets.delete(userId);
            break;
          }
        }
      });
    });
  }

  // Send notification to specific user
  sendNotificationToUser(userId: string, payload: NotificationPayload) {
    if (this.io) {
      this.io.to(userId).emit('notification', payload);
    }
  }

  // Broadcast notification to all users
  broadcastNotification(payload: NotificationPayload) {
    if (this.io) {
      this.io.emit('notification', payload);
    }
  }

  // Send notification to specific room
  sendNotificationToRoom(room: string, payload: NotificationPayload) {
    if (this.io) {
      this.io.to(room).emit('notification', payload);
    }
  }

  // Emit order status update
  emitOrderUpdate(orderId: string, status: string, userId: string) {
    const payload: NotificationPayload = {
      type: 'ORDER_STATUS',
      title: 'Order Status Updated',
      message: `Your order #${orderId} has been updated to ${status}`,
      orderId,
      userId,
      timestamp: new Date()
    };
    
    this.sendNotificationToUser(userId, payload);
  }

  // Emit inventory update
  emitStockUpdate(productId: string, productName: string, newStock: number) {
    const payload: NotificationPayload = {
      type: 'STOCK_UPDATE',
      title: 'Stock Update',
      message: `${productName} now has ${newStock} items in stock`,
      productId,
      timestamp: new Date()
    };
    
    // Broadcast to all users interested in this product
    this.broadcastNotification(payload);
  }

  // Emit promotion notification
  emitPromotion(promotion: { title: string; message: string; discount: number }) {
    const payload: NotificationPayload = {
      type: 'PROMOTION',
      title: promotion.title,
      message: promotion.message,
      timestamp: new Date()
    };
    
    this.broadcastNotification(payload);
  }
}

export const notificationService = new NotificationService();
export default notificationService;