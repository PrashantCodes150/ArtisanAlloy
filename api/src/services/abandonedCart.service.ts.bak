import { Cart, User } from '../models';
import { sendEmail } from '../utils/emailService';
import { logger } from '../utils/logger';

export interface AbandonedCartEmailTemplate {
  firstName: string;
  cartValue: number;
  cartItemsCount: number;
  recoveryLink: string;
  discountCode?: string;
}

class AbandonedCartService {
  /**
   * Check for abandoned carts and send recovery emails
   */
  async checkForAbandonedCarts(): Promise<void> {
    try {
      // Find carts that haven't been updated in the last 1-2 hours
      const oneHourAgo = new Date(Date.now() - 60 * 60 * 1000); // 1 hour ago
      const twoHoursAgo = new Date(Date.now() - 2 * 60 * 60 * 1000); // 2 hours ago
      
      const abandonedCarts = await Cart.find({
        updatedAt: { $lt: oneHourAgo },
        createdAt: { $gt: twoHoursAgo }, // Created more than 1 hour ago but less than 2 hours ago
        isAbandoned: { $ne: true }, // Not already marked as abandoned
        items: { $ne: [] } // Has items in cart
      }).populate('user', 'firstName email');

      for (const cart of abandonedCarts) {
        if (cart.user) {
          await this.sendAbandonedCartEmail(cart);
          
          // Mark cart as abandoned to avoid duplicate emails
          cart.isAbandoned = true;
          await cart.save();
        }
      }

      logger.info(`Processed ${abandonedCarts.length} abandoned carts`);
    } catch (error) {
      logger.error('Error checking for abandoned carts:', error);
    }
  }

  /**
   * Send abandoned cart recovery email
   */
  async sendAbandonedCartEmail(cart: any): Promise<boolean> {
    try {
      const user = cart.user;
      const cartValue = cart.items.reduce((total: number, item: any) => total + (item.price * item.quantity), 0);
      
      const templateData: AbandonedCartEmailTemplate = {
        firstName: user.firstName,
        cartValue,
        cartItemsCount: cart.items.length,
        recoveryLink: `${process.env.FRONTEND_URL}/cart`,
        discountCode: 'SAVE10' // Optional discount incentive
      };

      const emailSent = await sendEmail({
        to: user.email,
        subject: `Don't forget your items in your cart!`,
        html: this.abandonedCartEmailTemplate(templateData)
      });

      if (emailSent) {
        logger.info(`Abandoned cart email sent to ${user.email}`);
      } else {
        logger.error(`Failed to send abandoned cart email to ${user.email}`);
      }

      return emailSent;
    } catch (error) {
      logger.error('Error sending abandoned cart email:', error);
      return false;
    }
  }

  /**
   * Schedule periodic checks for abandoned carts
   */
  scheduleAbandonedCartChecks(intervalMinutes: number = 60): void {
    setInterval(() => {
      this.checkForAbandonedCarts();
    }, intervalMinutes * 60 * 1000);

    logger.info(`Scheduled abandoned cart checks every ${intervalMinutes} minutes`);
  }

  /**
   * Abandoned cart email template
   */
  private abandonedCartEmailTemplate(data: AbandonedCartEmailTemplate): string {
    return `
      <!DOCTYPE html>
      <html>
      <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Complete Your Purchase - F Jewelry</title>
        <style>
          body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #1a1a2e; color: #ffffff; margin: 0; padding: 0; }
          .container { max-width: 600px; margin: 0 auto; padding: 40px 20px; }
          .header { text-align: center; margin-bottom: 40px; }
          .logo { font-size: 32px; font-weight: bold; color: #d4af37; }
          .content { background: linear-gradient(135deg, #16213e 0%, #1a1a2e 100%); border-radius: 16px; padding: 40px; border: 1px solid rgba(212, 175, 55, 0.3); }
          h1 { color: #d4af37; margin-bottom: 20px; }
          p { line-height: 1.8; color: #e0e0e0; margin-bottom: 20px; }
          .button { display: inline-block; background: linear-gradient(135deg, #d4af37 0%, #f4d03f 100%); color: #1a1a2e; padding: 16px 40px; text-decoration: none; border-radius: 50px; font-weight: bold; margin: 20px 0; }
          .cart-summary { background: rgba(212, 175, 55, 0.1); border: 1px solid rgba(212, 175, 55, 0.3); border-radius: 8px; padding: 20px; margin: 20px 0; }
          .discount-badge { background: #d4af37; color: #1a1a2e; padding: 8px 16px; border-radius: 20px; font-weight: bold; display: inline-block; margin: 10px 0; }
          .footer { text-align: center; margin-top: 40px; color: #888; font-size: 14px; }
        </style>
      </head>
      <body>
        <div class="container">
          <div class="header">
            <div class="logo">✦ F Jewelry</div>
          </div>
          <div class="content">
            <h1>Complete Your Purchase</h1>
            <p>Hello ${data.firstName},</p>
            <p>We noticed you left <strong>${data.cartItemsCount} item(s)</strong> in your cart worth <strong>₹${data.cartValue.toLocaleString()}</strong>.</p>
            
            <div class="cart-summary">
              <p style="margin: 0; text-align: center; font-size: 18px;">Your cart is waiting for you!</p>
            </div>

            ${data.discountCode ? `
            <p>As a thank you for coming back, here's a special discount code:</p>
            <div class="discount-badge">${data.discountCode}</div>
            <p>Use this code at checkout for an extra 10% off!</p>
            ` : ''}

            <p style="text-align: center;">
              <a href="${data.recoveryLink}" class="button">Complete Your Purchase</a>
            </p>

            <p>This offer expires in 24 hours, so don't wait too long!</p>
            
            <p>If you've already completed your purchase, please disregard this email.</p>
          </div>
          <div class="footer">
            <p>© ${new Date().getFullYear()} F Jewelry. All rights reserved.</p>
            <p>Questions? Contact us at support@f-jewelry.com</p>
          </div>
        </div>
      </body>
      </html>
    `;
  }
}

export const abandonedCartService = new AbandonedCartService();
export default abandonedCartService;