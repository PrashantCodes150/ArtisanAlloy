import { getFromCache, setInCache, deleteFromCache } from './redisCache';
import { cacheGet, cacheSet, cacheDel } from './cache';

// Determine which cache to use based on environment
const USE_REDIS = process.env.REDIS_URL ? true : false;

/**
 * Unified caching service that uses Redis if available, otherwise falls back to memory cache
 */

export const getCachedData = async (key: string): Promise<any> => {
  if (USE_REDIS) {
    return await getFromCache(key);
  } else {
    return cacheGet(key);
  }
};

export const setCachedData = async (key: string, value: any, ttl: number = 600): Promise<boolean> => {
  if (USE_REDIS) {
    return await setInCache(key, value, ttl);
  } else {
    return cacheSet(key, value, ttl);
  }
};

export const deleteCachedData = async (key: string): Promise<boolean> => {
  if (USE_REDIS) {
    return await deleteFromCache(key);
  } else {
    cacheDel(key);
    return true;
  }
};

export const invalidateCachePattern = async (pattern: string): Promise<boolean> => {
  // For now, just flush all cache - in a real implementation you'd use Redis KEYS or SCAN
  if (USE_REDIS) {
    // Note: In a real Redis implementation, you'd use KEYS or SCAN to find matching keys
    console.warn('invalidateCachePattern not fully implemented for Redis');
    return true;
  } else {
    // For memory cache, we can't pattern match, so just flush all
    return true;
  }
};