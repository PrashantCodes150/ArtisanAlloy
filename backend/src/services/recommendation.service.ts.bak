import { Product } from '../models';

export interface RecommendationOptions {
  userId?: string;
  category?: string;
  tags?: string[];
  limit?: number;
  excludeIds?: string[];
}

class RecommendationService {
  /**
   * Get personalized product recommendations for a user
   */
  async getUserRecommendations(userId: string, options: RecommendationOptions = {}): Promise<any[]> {
    const limit = options.limit || 10;
    
    // In a real implementation, this would use ML algorithms
    // For now, returning similar products based on category and tags
    
    try {
      // Get user's browsing/purchase history to determine preferences
      // This would come from a user activity tracking system
      
      // For demo purposes, return random products from similar categories
      const pipeline = [
        {
          $match: {
            _id: { $ne: options.excludeIds }, // Exclude specific IDs if provided
            isActive: true,
            stock: { $gt: 0 } // Only show in-stock items
          }
        },
        {
          $addFields: {
            similarityScore: {
              $add: [
                { $cond: [{ $eq: ['$category', options.category] }, 10, 0] }, // Category match
                { $size: { $setIntersection: ['$tags', options.tags || []] } } // Tag intersection
              ]
            }
          }
        },
        { $sort: { similarityScore: -1, rating: -1, createdAt: -1 } },
        { $limit: limit }
      ];

      const recommendations = await Product.aggregate(pipeline);
      return recommendations;
    } catch (error) {
      console.error('Error getting recommendations:', error);
      // Fallback to popular products
      return await this.getPopularProducts(limit);
    }
  }

  /**
   * Get popular products
   */
  async getPopularProducts(limit: number = 10): Promise<any[]> {
    try {
      return await Product.find({ 
        isActive: true, 
        stock: { $gt: 0 } 
      })
      .sort({ rating: -1, salesCount: -1 })
      .limit(limit);
    } catch (error) {
      console.error('Error getting popular products:', error);
      return [];
    }
  }

  /**
   * Get trending products
   */
  async getTrendingProducts(limit: number = 10): Promise<any[]> {
    try {
      // In a real implementation, this would factor in recent sales, views, etc.
      return await Product.find({ 
        isActive: true, 
        stock: { $gt: 0 },
        isNewArrival: true
      })
      .sort({ createdAt: -1 })
      .limit(limit);
    } catch (error) {
      console.error('Error getting trending products:', error);
      return [];
    }
  }

  /**
   * Get frequently bought together
   */
  async getFrequentlyBoughtTogether(productId: string, limit: number = 5): Promise<any[]> {
    try {
      // This would typically come from order analysis
      // For demo, return related products from same category
      const product = await Product.findById(productId);
      if (!product) return [];

      return await Product.find({
        category: product.category,
        _id: { $ne: productId },
        isActive: true,
        stock: { $gt: 0 }
      })
      .limit(limit);
    } catch (error) {
      console.error('Error getting frequently bought together:', error);
      return [];
    }
  }

  /**
   * Get seasonal/recommendations based on occasion
   */
  async getOccasionRecommendations(occasion: string, limit: number = 10): Promise<any[]> {
    try {
      return await Product.find({
        'occasion': occasion,
        isActive: true,
        stock: { $gt: 0 }
      })
      .limit(limit);
    } catch (error) {
      console.error('Error getting occasion recommendations:', error);
      return [];
    }
  }
}

export const recommendationService = new RecommendationService();
export default recommendationService;