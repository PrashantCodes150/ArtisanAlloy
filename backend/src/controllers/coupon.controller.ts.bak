    data: { coupons }
  });
});

/**
 * Get coupon analytics
 * GET /api/v1/coupons/analytics
 */
export const getCouponAnalytics = asyncHandler(async (req: Request, res: Response) => {
  const { period = '30' } = req.query;
  const days = parseInt(period as string);
  const startDate = new Date();
  startDate.setDate(startDate.getDate() - days);

  const [
    totalCoupons,
    activeCoupons,
    expiredCoupons,
    totalUsage,
    popularCoupons,
    recentUsage
  ] = await Promise.all([
    Coupon.countDocuments(),
    Coupon.countDocuments({
      isActive: true,
      validFrom: { $lte: new Date() },
      validUntil: { $gte: new Date() }
    }),
    Coupon.countDocuments({ validUntil: { $lt: new Date() } }),
    Coupon.aggregate([
      { $match: { usedAt: { $gte: startDate } } },
      { $unwind: '$usedBy' },
      { $match: { 'usedBy.usedAt': { $gte: startDate } } },
      { $group: { _id: null, totalUsage: { $sum: 1 } } }
    ]),
    Coupon.aggregate([
      { $unwind: '$usedBy' },
      { $match: { 'usedBy.usedAt': { $gte: startDate } } },
      { $group: { _id: '$_id', usageCount: { $sum: 1 }, discountAmount: { $sum: '$usedBy.discountAmount' } } },
      { $sort: { usageCount: -1 } },
      { $limit: 10 },
      { $lookup: { from: 'coupons', localField: '_id', foreignField: '_id', as: 'coupon' } },
      { $unwind: '$coupon' },
      { $project: { code: '$coupon.code', usageCount: 1, discountAmount: 1 } }
    ]),
    Coupon.aggregate([
      { $unwind: '$usedBy' },
      { $match: { 'usedBy.usedAt': { $gte: startDate } } },
      { $sort: { 'usedBy.usedAt': -1 } },
      { $limit: 10 },
      { $lookup: { from: 'users', localField: 'usedBy.user', foreignField: '_id', as: 'user' } },
      { $lookup: { from: 'orders', localField: 'usedBy.orderId', foreignField: '_id', as: 'order' } },
      { $project: {
        couponCode: '$code',
        userEmail: { $arrayElemAt: ['$user.email', 0] },
        orderId: { $arrayElemAt: ['$order._id', 0] },
        discountAmount: '$usedBy.discountAmount',
        usedAt: '$usedBy.usedAt'
      }}
    ])
  ]);

  res.status(200).json({
    status: 'success',
    data: {
      overview: {
        totalCoupons,
        activeCoupons,
        expiredCoupons,
        totalUsage: totalUsage[0]?.totalUsage || 0
      },
      popularCoupons,
      recentUsage,
      period: `${days} days`
    }
  });
});